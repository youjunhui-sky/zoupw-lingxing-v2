# 领星 ERP
LX_APP_ID=your_app_id
LX_APP_SECRET=enc:            # Fernet 密文(enc:<token>);明文亦可但生产请加密

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lingxing
POSTGRES_USER=lingxing
POSTGRES_PASSWORD=enc:         # Fernet 密文

# Redis
REDIS_URL=redis://localhost:6379/0

# 飞书机器人
FEISHU_DAILY_WEBHOOK=enc:      # Fernet 密文
FEISHU_ALERT_WEBHOOK=enc:      # Fernet 密文
FEISHU_WEEKLY_WEBHOOK=enc:     # Fernet 密文

# Metabase
METABASE_URL=http://localhost:3000
METABASE_USERNAME=admin@example.com
METABASE_PASSWORD=changeme

# 调度
SYNC_ORDER_INTERVAL_MINUTES=60
SYNC_INVENTORY_INTERVAL_MINUTES=120
SYNC_ADS_CRON_HOUR=6
DAILY_REPORT_CRON_HOUR=9

# --------------------------------------------------------------------------
# Secret 加密说明
# --------------------------------------------------------------------------
# 敏感字段(8 个: LX_APP_SECRET / POSTGRES_PASSWORD / 3 个 FEISHU_*_WEBHOOK /
#  完整的还有 LX_DOC_SECRET / FEISHU_APP_SECRET / FEISHU_BITABLE_APP_TOKEN)
# 部署前必须用 enc: 前缀加密存储,详见 scripts/encrypt_env.py
#
# 首次部署:
#   1) 生成 key:    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   2) export LINGXING_ENC_KEY=<key>
#   3) 填明文到 .env, 跑: python scripts/encrypt_env.py
#   4) 部署时把 LINGXING_ENC_KEY 通过 systemd EnvironmentFile= 或 K8s Secret 注入
#
# 缺 LINGXING_ENC_KEY 时仅 WARNING,不抛(开发态友好);
# 但检测到密文 + 缺 key 会抛 RuntimeError —— 避免静默拿到无意义字符串
